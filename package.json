{
  "name": "naver-blog-app",
  "version": "1.1.2",
  "description": "네이버 블로그 자동화 앱",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "build": "npm run react-build && electron-builder",
    "build:mac": "npm run react-build && electron-builder --mac",
    "build:win": "npm run react-build && electron-builder --win",
    "electron": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": null,
    "appId": "com.naverblog.app",
    "productName": "네이버 블로그 자동화",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": ["nsis"]
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "src/db.js",
      "license/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "SH8952",
      "repo": "naver-blog-automation-releases"
    }
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
